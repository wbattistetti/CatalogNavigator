{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev-vite.ts",
    "dev:convai": "powershell -ExecutionPolicy Bypass -File scripts/dev-convai.ps1",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "functions:serve": "supabase functions serve analyze-document --env-file supabase/functions/.env",
    "be:gateway": "tsx backend/server.ts",
    "vb:api": "dotnet run --project dialog-engine/src/DialogEngine.Api/DialogEngine.Api.csproj",
    "db:migrate": "supabase migration up --local",
    "db:migrate:remote": "supabase db push",
    "db:seed-pharma": "tsx scripts/seed-pharma-dictionary.ts",
    "db:seed-idi": "tsx scripts/seed-idi-dictionary.ts",
    "db:populate-pharma": "tsx scripts/populate-pharma-from-csv.ts"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "@ngrok/ngrok": "^1.4.1",
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/zoom": "^3.12.0",
    "@supabase/supabase-js": "^2.57.4",
    "ag-grid-community": "^35.3.1",
    "ag-grid-react": "^35.3.1",
    "cors": "^2.8.5",
    "dockview": "^4.13.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lodash": "^4.18.1",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.12.0",
    "marked": "^4.3.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-responsive-carousel": "^3.2.23",
    "reactflow": "^11.11.4",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
